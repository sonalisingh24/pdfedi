<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurfaceVariant">

    <com.example.pdfedi.ZoomableRecyclerView
        android:id="@+id/pdf_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="100dp"
        android:paddingBottom="160dp" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/top_bar_card"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="?attr/colorSurface"
        android:layout_gravity="top">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_back"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:icon="@drawable/ic_undo"
                android:rotation="90"
                app:iconTint="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/tv_document_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Editing PDF..."
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_search"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:icon="@android:drawable/ic_menu_search"
                app:iconTint="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_mode"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:icon="@android:drawable/ic_menu_view"
                app:iconTint="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:icon="@drawable/ic_save"
                app:iconTint="?attr/colorPrimary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:gravity="center_horizontal"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tool_options_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            android:visibility="gone"
            app:cardBackgroundColor="?attr/colorSurface">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingVertical="16dp">

                <LinearLayout
                    android:id="@+id/options_pen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <SeekBar
                        android:id="@+id/slider_thickness"
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:max="30"
                        android:min="2"
                        android:progress="8"
                        android:progressTint="?attr/colorPrimary"
                        android:thumbTint="?attr/colorPrimary" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <com.google.android.material.card.MaterialCardView android:id="@+id/color_black" android:layout_width="28dp" android:layout_height="28dp" android:layout_marginHorizontal="6dp" app:cardCornerRadius="14dp" app:cardBackgroundColor="#212121" app:strokeWidth="0dp" android:clickable="true" android:focusable="true"/>
                        <com.google.android.material.card.MaterialCardView android:id="@+id/color_red" android:layout_width="28dp" android:layout_height="28dp" android:layout_marginHorizontal="6dp" app:cardCornerRadius="14dp" app:cardBackgroundColor="#F44336" app:strokeWidth="0dp" android:clickable="true" android:focusable="true"/>
                        <com.google.android.material.card.MaterialCardView android:id="@+id/color_blue" android:layout_width="28dp" android:layout_height="28dp" android:layout_marginHorizontal="6dp" app:cardCornerRadius="14dp" app:cardBackgroundColor="#2196F3" app:strokeWidth="0dp" android:clickable="true" android:focusable="true"/>
                        <com.google.android.material.card.MaterialCardView android:id="@+id/color_green" android:layout_width="28dp" android:layout_height="28dp" android:layout_marginHorizontal="6dp" app:cardCornerRadius="14dp" app:cardBackgroundColor="#4CAF50" app:strokeWidth="0dp" android:clickable="true" android:focusable="true"/>
                        <com.google.android.material.card.MaterialCardView android:id="@+id/color_yellow" android:layout_width="28dp" android:layout_height="28dp" android:layout_marginHorizontal="6dp" app:cardCornerRadius="14dp" app:cardBackgroundColor="#FFEB3B" app:strokeWidth="0dp" android:clickable="true" android:focusable="true"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/options_eraser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_eraser_stroke"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stroke" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_eraser_pixel"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Pixel" />
                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/bottom_tool_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="32dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="?attr/colorSurface">

            <HorizontalScrollView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:overScrollMode="never">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:paddingHorizontal="8dp"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_undo"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:icon="@drawable/ic_undo"
                        app:iconTint="?attr/colorOnSurfaceVariant" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_redo"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:icon="@drawable/ic_redo"
                        app:iconTint="?attr/colorOnSurfaceVariant" />

                    <View android:layout_width="1dp" android:layout_height="32dp" android:background="?attr/colorOutlineVariant" android:layout_marginHorizontal="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/tool_hand"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="4dp"
                        app:icon="@drawable/ic_hand"
                        app:iconTint="?attr/colorOnPrimary"
                        app:backgroundTint="?attr/colorPrimary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/tool_pen"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="4dp"
                        app:icon="@drawable/ic_marker"
                        app:iconTint="?attr/colorOnSurfaceVariant"
                        app:backgroundTint="@android:color/transparent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/tool_highlighter"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="4dp"
                        app:icon="@drawable/ic_highlighter"
                        app:iconTint="?attr/colorOnSurfaceVariant"
                        app:backgroundTint="@android:color/transparent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/tool_text_hl"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginStart="4dp"
                        android:text="Text HL"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        app:backgroundTint="@android:color/transparent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/tool_eraser"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="4dp"
                        app:icon="@drawable/ic_eraser"
                        app:iconTint="?attr/colorOnSurfaceVariant"
                        app:backgroundTint="@android:color/transparent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/tool_note"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:text="Note"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        app:backgroundTint="@android:color/transparent" />

                </LinearLayout>
            </HorizontalScrollView>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>