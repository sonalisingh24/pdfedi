<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#F5F7FA">

    <com.example.pdfedi.ZoomableRecyclerView
        android:id="@+id/pdfRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/topToolbarCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="6dp"
            android:gravity="center_vertical">

            <ImageButton android:id="@+id/btnOpenPdf" android:layout_width="40dp" android:layout_height="40dp" android:background="?android:attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_open" android:tint="#424242" />
            <ImageButton android:id="@+id/btnSavePdf" android:layout_width="40dp" android:layout_height="40dp" android:background="?android:attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_save" android:tint="#424242" />
            <View android:layout_width="1dp" android:layout_height="24dp" android:background="#E0E0E0" android:layout_marginHorizontal="8dp"/>
            <Button android:id="@+id/btnSearch" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Search" android:textSize="11sp" android:backgroundTint="#ECEFF1" android:textColor="#263238" app:cornerRadius="18dp"/>
            <Button android:id="@+id/btnToggleReadingMode" android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginStart="4dp" android:text="Mode" android:textSize="11sp" android:backgroundTint="#ECEFF1" android:textColor="#263238" app:cornerRadius="18dp"/>
            <Button android:id="@+id/btnToggleImmersive" android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginStart="4dp" android:text="Full" android:textSize="11sp" android:backgroundTint="#ECEFF1" android:textColor="#263238" app:cornerRadius="18dp"/>
            <View android:layout_width="1dp" android:layout_height="24dp" android:background="#E0E0E0" android:layout_marginHorizontal="8dp"/>
            <ImageButton android:id="@+id/btnUndo" android:layout_width="40dp" android:layout_height="40dp" android:background="?android:attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_undo" android:tint="#424242" />
            <ImageButton android:id="@+id/btnRedo" android:layout_width="40dp" android:layout_height="40dp" android:background="?android:attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_redo" android:tint="#424242" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/settingsPanelCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:visibility="gone"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomToolbarCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical">

            <Button android:id="@+id/btnColorRed" android:layout_width="32dp" android:layout_height="32dp" android:backgroundTint="#F44336" app:cornerRadius="16dp" />
            <Button android:id="@+id/btnColorGreen" android:layout_width="32dp" android:layout_height="32dp" android:layout_marginStart="8dp" android:backgroundTint="#4CAF50" app:cornerRadius="16dp"/>
            <Button android:id="@+id/btnColorBlue" android:layout_width="32dp" android:layout_height="32dp" android:layout_marginStart="8dp" android:backgroundTint="#2196F3" app:cornerRadius="16dp"/>
            <View android:layout_width="1dp" android:layout_height="24dp" android:background="#E0E0E0" android:layout_marginHorizontal="12dp"/>
            <Button android:id="@+id/btnSizeThin" android:layout_width="wrap_content" android:layout_height="32dp" android:text="Thin" android:textSize="10sp" android:backgroundTint="#757575" app:cornerRadius="16dp"/>
            <Button android:id="@+id/btnSizeMed" android:layout_width="wrap_content" android:layout_height="32dp" android:layout_marginStart="4dp" android:text="Med" android:textSize="10sp" android:backgroundTint="#424242" app:cornerRadius="16dp"/>
            <Button android:id="@+id/btnSizeThick" android:layout_width="wrap_content" android:layout_height="32dp" android:layout_marginStart="4dp" android:text="Thick" android:textSize="10sp" android:backgroundTint="#212121" app:cornerRadius="16dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomToolbarCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="10dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical">

            <ImageButton android:id="@+id/btnHand" android:layout_width="48dp" android:layout_height="48dp" android:backgroundTint="#4CAF50" android:src="@drawable/ic_hand" android:tint="@color/white" />
            <ImageButton android:id="@+id/btnMarker" android:layout_width="48dp" android:layout_height="48dp" android:layout_marginStart="8dp" android:backgroundTint="#B0BEC5" android:src="@drawable/ic_marker" android:tint="@color/white" />
            <ImageButton android:id="@+id/btnHighlighter" android:layout_width="48dp" android:layout_height="48dp" android:layout_marginStart="8dp" android:backgroundTint="#B0BEC5" android:src="@drawable/ic_highlighter" android:tint="@color/white" />

            <Button android:id="@+id/btnTextHighlighter" android:layout_width="wrap_content" android:layout_height="48dp" android:layout_marginStart="8dp" android:text="Text HL" android:textSize="12sp" android:backgroundTint="#B0BEC5" android:textColor="@color/white" app:cornerRadius="24dp"/>

            <ImageButton android:id="@+id/btnEraser" android:layout_width="48dp" android:layout_height="48dp" android:layout_marginStart="8dp" android:backgroundTint="#B0BEC5" android:src="@drawable/ic_eraser" android:tint="@color/white" />
            <Button android:id="@+id/btnNote" android:layout_width="wrap_content" android:layout_height="48dp" android:layout_marginStart="8dp" android:text="Note" android:textSize="12sp" android:backgroundTint="#B0BEC5" android:textColor="@color/white" app:cornerRadius="24dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>